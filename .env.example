# 本地开发环境配置
# 使用方法:
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 根据需要修改配置
#   3. 启动服务: make dev
#
# 配置优先级: 环境变量 > config.yaml > 默认值

# ── 运行环境 ────────────────────────────────
ENVIRONMENT=development

# ── 服务配置 ────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:5173
UPLOAD_PATH_PREFIX=/uploads/

# ── 数据库 ──────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=blog
DATABASE_USER=blog
DATABASE_PASSWORD=blog123
DATABASE_SSLMODE=disable

# ── Redis ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=./jwt_public_key.pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# ── 邮件服务 (Resend) ────────────────────────
# 开发环境可选，不配置则邮件功能不可用
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ── B站表情种子数据 ──────────────────────────
# 可选配置，用于初始化表情数据
# 登录 B站后，从浏览器 Console 执行 document.cookie 获取
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_DEDEUSERID=

# ── 超级管理员 ────────────────────────────────
# 开发环境可以启用，方便测试
SUPERADMIN_ENABLED=false
SUPERADMIN_USERNAME=admin
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=
