# 数据库配置
DATABASE_URL=postgres://blog:blog123@localhost:5432/blog?sslmode=disable

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 配置
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# 邮件服务配置
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# 前端地址
FRONTEND_URL=http://localhost:3000

# 服务端口
PORT=8080

# 上传路径前缀
UPLOAD_PATH_PREFIX=/uploads/

# B站表情种子数据配置
# 方式一：直接设置 Cookie（推荐）
# 登录 B站后，从浏览器开发者工具 -> Application -> Cookies -> bilibili.com 获取 SESSDATA
# Cookie 格式示例：SESSDATA=xxx; bili_jct=xxx; DedeUserID=xxx
BILIBILI_COOKIE=

# 方式二：账号密码（不推荐，可能因验证码失败）
BILIBILI_USERNAME=
BILIBILI_PASSWORD=