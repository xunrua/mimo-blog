# ── 服务配置 ────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:3000
UPLOAD_PATH_PREFIX=/uploads/

# ── 数据库 ──────────────────────────────────
# 格式: postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=disable
DATABASE_URL=postgres://blog:CHANGE_ME@localhost:5432/blog?sslmode=disable

# ── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ─────────────────────────────────────
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# ── 对象存储 (Cloudflare R2 / S3 兼容) ──────
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_PUBLIC_URL=

# ── 邮件服务 (Resend) ────────────────────────
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=noreply@yourdomain.com

# ── B站表情种子数据 ──────────────────────────
# 登录 B站后，从浏览器 Console 执行 document.cookie 获取以下三个值
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_DEDEUSERID=