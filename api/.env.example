# 环境变量配置示例
# 配置优先级：环境变量 > config.yaml > 默认值
#
# 主要配置通过 api/config.yaml 管理
# 此文件列出可用的环境变量覆盖选项

# ── 运行环境 ────────────────────────────────
# ENVIRONMENT=development

# ── 服务配置 ────────────────────────────────
# PORT=8080
# FRONTEND_URL=http://localhost:5173
# UPLOAD_PATH_PREFIX=/uploads/

# ── 数据库 ──────────────────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=blog
# DB_USER=blog
# DB_PASSWORD=blog123
# DB_SSLMODE=disable

# ── Redis ───────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────
# JWT_PRIVATE_KEY_PATH=./jwt_private_key.pem
# JWT_PUBLIC_KEY_PATH=./jwt_public_key.pem
# JWT_ACCESS_TOKEN_TTL=15m
# JWT_REFRESH_TOKEN_TTL=168h

# ── 对象存储 (Cloudflare R2 / S3 兼容) ──────
# S3_BUCKET=
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_PUBLIC_URL=

# ── 邮件服务 (Resend) ────────────────────────
# RESEND_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com

# ── B站表情种子数据 ──────────────────────────
# 登录 B站后，从浏览器 Console 执行 document.cookie 获取以下三个值
# BILIBILI_SESSDATA=
# BILIBILI_BILI_JCT=
# BILIBILI_DEDEUSERID=

# ── 超级管理员 ────────────────────────────────
# SUPERADMIN_ENABLED=false
# SUPERADMIN_USERNAME=admin
# SUPERADMIN_EMAIL=admin@example.com
# SUPERADMIN_PASSWORD=
